{
    "python.defaultInterpreterPath": "./venv/Scripts/python.exe",
    "[python]": {
        "editor.defaultFormatter": "ms-python.python",
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },
    "files.exclude": {
        "**/__pycache__": true,
        "**/*.pyc": true
    },
    "flake8.args": [
        "--max-line-length=120"
    ],
    "flake8.enabled": false,
    "python.linting.pylintEnabled": false
}